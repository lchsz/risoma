get_cigar <- function(query, ref) {
query <- strsplit(query, "")[[1]]
ref <- strsplit(ref, "")[[1]]
cigar <- rep("M", length(query))
cigar[query == "-"] <- "D"
query[cigar == "D"] <- "D"
ref[cigar == "D"] <- "D"
cigar[ref == "-"] <- "I"
query[cigar == "I"] <- "I"
ref[cigar == "I"] <- "I"
cigar[query != ref] <- "U"
r <- rle(cigar)
paste0(as.character(r$lengths), r$values, collapse = "")
}
str1
str2
get_cigar(str1, str2)
