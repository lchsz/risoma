pw_align <- function(query, subject, sub_mat) {
alns <- pwalign::pairwiseAlignment(
pattern = query,
subject = subject,
substitutionMatrix = sub_mat,
gapOpening = 0,
gapExtension = 1,
type = "global"
)
aln <- alns[1]
str1 <- as.character(pwalign::alignedPattern(aln))
str2 <- as.character(pwalign::alignedSubject(aln))
return([str1, str2])
pw_align <- function(query, subject, sub_mat) {
alns <- pwalign::pairwiseAlignment(
pattern = query,
subject = subject,
substitutionMatrix = sub_mat,
gapOpening = 0,
gapExtension = 1,
type = "global"
)
aln <- alns[1]
str1 <- as.character(pwalign::alignedPattern(aln))
str2 <- as.character(pwalign::alignedSubject(aln))
}
pw_align <- function(query, subject, sub_mat) {
alns <- pwalign::pairwiseAlignment(
pattern = query,
subject = subject,
substitutionMatrix = sub_mat,
gapOpening = 0,
gapExtension = 1,
type = "global"
)
aln <- alns[1]
str1 <- as.character(pwalign::alignedPattern(aln))
str2 <- as.character(pwalign::alignedSubject(aln))
return(c(str1, str2))
}
