get_cigar <- function(query, ref) {
query <- strsplit(query, "")[[1]]
ref <- strsplit(ref, "")[[1]]
cigar <- rep("M", length(query))
cigar[query == "-"] <- "D"
cigar[ref == "-"] <- "I"
r <- rle(cigar)
paste0(as.character(r$lengths), r$values, collapse = "")
}
